{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@wolfstar-project/dashboard",
  "version": "2.0.0",
  "private": true,
  "description": "WolfStar is a multipurpose Discord bot designed to handle most tasks, helping users manage their servers easily.",
  "homepage": "https://wolfstar.rocks",
  "main": "./nuxt.config.ts",
  "bugs": {
    "url": "https://github.com/wolfstar-project/wolfstar.rocks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wolfstar-project/wolfstar.rocks.git"
  },
  "funding": "https://github.com/wolfstar-project/wolfstar.rocks?sponsor",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:playwright": "NODE_ENV=test pnpm build",
    "dev": "nuxt dev",
    "dev:pwa": "VITE_DEV_PWA=true nuxt dev",
    "generate": "nuxt generate",
    "lint": "lintroll --cache .",
    "lint:fix": "lintroll --fix --cache .",
    "postinstall": "stale-dep -u && nuxt prepare",
    "prepare": "node .husky/install.mjs",
    "generate-pwa-icons": "pwa-assets-generator",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:dev:create": "prisma migrate dev --create-only",
    "prisma:migrate:diff": "prisma migrate diff --exit-code --from-migrations server/database/migrations --to-schema-datamodel server/database/schema.prisma --shadow-database-url",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:resolve": "prisma migrate resolve",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:generate:watch": "prisma generate --watch",
    "test": "vitest",
    "test:browser": "pnpm build:playwright && pnpm test:browser:prebuilt",
    "test:browser:prebuilt": "playwright test",
    "test:browser:ui": "pnpm build:playwright && pnpm test:browser:prebuilt --ui",
    "test:browser:update": "pnpm build:playwright && pnpm test:browser:prebuilt --update-snapshots",
    "test:nuxt": "vitest --project nuxt",
    "test:unit": "vitest --project unit",
    "start:playwright:webserver": "NODE_ENV=test pnpm preview --port 5678",
    "typecheck": "stale-dep && nuxt typecheck",
    "release": "bumpp && node scripts/release.ts",
    "upgrade:interactive": "taze"
  },
  "lint-staged": {
    "*": "pnpm lintroll --fix --cache --staged ."
  },
  "dependencies": {
    "@nuxt/fonts": "catalog:prod",
    "@nuxt/a11y": "catalog:prod",
    "@nuxt/icon": "catalog:icons",
    "@nuxt/image": "catalog:prod",
    "@nuxt/ui": "catalog:frontend",
    "@nuxtjs/seo": "catalog:prod",
    "@prisma/adapter-pg": "catalog:database",
    "@prisma/client": "catalog:database",
    "@sapphire/ratelimits": "catalog:prod",
    "@sentry/nuxt": "catalog:prod",
    "@vueuse/core": "catalog:utils",
    "@vueuse/integrations": "catalog:utils",
    "@vueuse/motion": "catalog:utils",
    "@vueuse/nuxt": "catalog:utils",
    "@vueuse/router": "catalog:utils",
    "consola": "catalog:node",
    "defu": "catalog:utils",
    "dotenv": "catalog:node",
    "fuse.js": "catalog:utils",
    "import-in-the-middle": "catalog:prod",
    "nuxt": "catalog:prod",
    "nuxt-auth-utils": "catalog:utils",
    "nuxt-security": "catalog:prod",
    "nuxt-vitalizer": "catalog:prod",
    "postcss-nested": "catalog:style",
    "require-in-the-middle": "catalog:prod",
    "rou3": "catalog:utils",
    "simple-git": "catalog:prod",
    "stale-dep": "catalog:prod",
    "std-env": "catalog:node",
    "tailwind-merge": "catalog:style",
    "tailwind-variants": "catalog:style",
    "tw-animate-css": "catalog:style",
    "utility-types": "catalog:prod",
    "yup": "catalog:prod",
    "@vitest/coverage-v8": "catalog:test",
    "@vitest/browser-playwright": "catalog:test",
    "@playwright/test": "catalog:test",
    "vitest": "catalog:test",
    "@vue/test-utils": "catalog:test",
    "sharp": "catalog:prod"
  },
  "devDependencies": {
    "@iconify-json/emojione": "catalog:icons",
    "@iconify-json/heroicons": "catalog:icons",
    "@iconify-json/ic": "catalog:icons",
    "@iconify-json/lucide": "catalog:icons",
    "@iconify-json/ph": "catalog:icons",
    "@antfu/eslint-config": "catalog:lint",
    "@antfu/nip": "catalog:dev",
    "@commitlint/cli": "catalog:lint",
    "@vite-pwa/nuxt": "catalog:build",
    "@commitlint/config-conventional": "catalog:lint",
    "@nuxt/test-utils": "catalog:test",
    "@discordjs/collection": "catalog:dev",
    "@discordjs/core": "catalog:dev",
    "@netlify/nuxt": "catalog:dev",
    "@nuxt/eslint": "catalog:lint",
    "@nuxt/hints": "catalog:dev",
    "@sapphire/bitfield": "catalog:dev",
    "@sapphire/prettier-config": "catalog:lint",
    "@sapphire/snowflake": "catalog:dev",
    "@sapphire/time-utilities": "catalog:dev",
    "@sapphire/utilities": "catalog:dev",
    "@tailwindcss/typography": "catalog:style",
    "@types/pg": "catalog:types",
    "@vite-pwa/assets-generator": "catalog:build",
    "@vue-macros/nuxt": "catalog:frontend",
    "bumpp": "catalog:cli",
    "cz-conventional-changelog": "catalog:dev",
    "daisyui": "catalog:dev",
    "discord-api-types": "catalog:dev",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "eslint-plugin-package-json": "catalog:lint",
    "eslint-plugin-vuejs-accessibility": "catalog:lint",
    "husky": "catalog:lint",
    "lint-staged": "catalog:lint",
    "lintroll": "catalog:lint",
    "pncat": "catalog:cli",
    "prettier": "catalog:lint",
    "prettier-plugin-css-order": "catalog:lint",
    "prettier-plugin-tailwindcss": "catalog:lint",
    "prisma": "catalog:database",
    "prisma-json-types-generator": "catalog:database",
    "tailwindcss": "catalog:style",
    "taze": "catalog:cli",
    "typescript": "catalog:tsc",
    "vue-tsc": "catalog:tsc"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "24.13.0"
  }
}
