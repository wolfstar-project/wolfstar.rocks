{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@wolfstar-project/dashboard",
	"version": "2.0.0",
	"private": true,
	"description": "WolfStar is a multipurpose Discord bot designed to handle most tasks, helping users manage their servers easily.",
	"homepage": "https://wolfstar.rocks",
	"bugs": {
		"url": "https://github.com/wolfstar-project/wolfstar.rocks/issues"
	},
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wolfstar-project/wolfstar.rocks.git"
	},
	"funding": "https://github.com/wolfstar-project/wolfstar.rocks?sponsor",
	"type": "module",
	"main": "./nuxt.config.ts",
	"scripts": {
		"build": "nuxt build",
		"build:playwright": "NODE_ENV=test pnpm build",
		"dev": "nuxt dev",
		"dev:pwa": "VITE_DEV_PWA=true nuxt dev",
		"generate": "nuxt generate",
		"lint": "oxlint && oxfmt --check",
		"lint:fix": "oxlint --fix && oxfmt",
		"postinstall": "stale-dep -u && nuxt prepare",
		"prepare": "node .husky/install.mjs",
		"generate-pwa-icons": "pwa-assets-generator",
		"prisma:migrate:dev": "prisma migrate dev",
		"prisma:migrate:dev:create": "prisma migrate dev --create-only",
		"prisma:migrate:diff": "prisma migrate diff --exit-code --from-migrations server/database/migrations --to-schema-datamodel server/database/schema.prisma --shadow-database-url",
		"prisma:migrate:reset": "prisma migrate reset",
		"prisma:migrate:deploy": "prisma migrate deploy",
		"prisma:migrate:status": "prisma migrate status",
		"prisma:migrate:resolve": "prisma migrate resolve",
		"prisma:push": "prisma db push",
		"prisma:seed": "prisma db seed",
		"prisma:studio": "prisma studio",
		"prisma:generate": "prisma generate",
		"prisma:generate:watch": "prisma generate --watch",
		"test": "vitest",
		"test:browser": "pnpm build:playwright && pnpm test:browser:prebuilt",
		"test:browser:prebuilt": "playwright test",
		"test:browser:ui": "pnpm build:playwright && pnpm test:browser:prebuilt --ui",
		"test:browser:update": "pnpm build:playwright && pnpm test:browser:prebuilt --update-snapshots",
		"test:nuxt": "vitest --project nuxt",
		"test:unit": "vitest --project unit",
		"start:playwright:webserver": "NODE_ENV=test pnpm preview --port 5678",
		"typecheck": "stale-dep && nuxt typecheck",
		"release": "bump && node scripts/release.ts",
		"upgrade:interactive": "taze"
	},
	"dependencies": {
		"@nuxt/a11y": "^1.0.0-alpha.1",
		"@nuxt/fonts": "^0.13.0",
		"@nuxt/icon": "^2.2.1",
		"@nuxt/image": "^2.0.0",
		"@nuxt/ui": "^4.4.0",
		"@nuxtjs/seo": "^3.3.0",
		"@playwright/test": "^1.58.0",
		"@prisma/adapter-pg": "^6.19.0",
		"@prisma/client": "^6.19.0",
		"@sapphire/ratelimits": "^2.4.11",
		"@sentry/nuxt": "^10.36.0",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"@vue/test-utils": "^2.4.6",
		"@vueuse/core": "^14.2.0",
		"@vueuse/integrations": "^14.2.0",
		"@vueuse/motion": "^3.0.3",
		"@vueuse/nuxt": "^14.2.0",
		"@vueuse/router": "^14.2.0",
		"consola": "^3.4.2",
		"defu": "^6.1.4",
		"dotenv": "^17.2.3",
		"fuse.js": "^7.1.0",
		"import-in-the-middle": "^2.0.5",
		"nuxt": "^4.3.1",
		"nuxt-auth-utils": "^0.5.27",
		"nuxt-security": "^2.5.1",
		"nuxt-vitalizer": "^2.0.0",
		"postcss-nested": "^7.0.2",
		"require-in-the-middle": "^8.0.1",
		"rou3": "^0.7.12",
		"sharp": "^0.34.5",
		"simple-git": "^3.30.0",
		"stale-dep": "^0.8.4",
		"std-env": "^3.10.0",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"utility-types": "^3.11.0",
		"vitest": "^4.0.18",
		"yup": "^1.7.1"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^7.2.0",
		"@antfu/nip": "^0.1.1",
		"@commitlint/cli": "^20.3.1",
		"@commitlint/config-conventional": "^20.3.1",
		"@discordjs/collection": "^2.1.1",
		"@discordjs/core": "^2.4.0",
		"@iconify-json/emojione": "^1.2.3",
		"@iconify-json/heroicons": "^1.2.3",
		"@iconify-json/ic": "^1.2.4",
		"@iconify-json/lucide": "^1.2.86",
		"@iconify-json/ph": "^1.2.2",
		"@netlify/nuxt": "^0.2.19",
		"@nuxt/eslint": "^1.13.0",
		"@nuxt/hints": "^1.0.0-alpha.5",
		"@nuxt/test-utils": "^4.0.0",
		"@sapphire/bitfield": "^1.2.4",
		"@sapphire/prettier-config": "^2.0.0",
		"@sapphire/snowflake": "^3.5.5",
		"@sapphire/time-utilities": "^1.7.14",
		"@sapphire/utilities": "^3.18.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/pg": "^8.16.0",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vite-pwa/nuxt": "^1.1.0",
		"@vue-macros/nuxt": "^3.1.1",
		"bumpp": "^10.4.0",
		"cz-conventional-changelog": "^3.3.0",
		"daisyui": "^5.5.14",
		"discord-api-types": "^0.38.37",
		"eslint": "^9.39.2",
		"eslint-plugin-format": "^1.3.1",
		"eslint-plugin-package-json": "^0.88.2",
		"eslint-plugin-vue-a11y": "^0.0.31",
		"eslint-plugin-vuejs-accessibility": "^2.4.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"lintroll": "^1.28.1",
		"oxfmt": "^0.28.0",
		"oxlint": "^1.43.0",
		"prettier": "^3.8.1",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"prisma": "^6.19.0",
		"prisma-json-types-generator": "^3.6.2",
		"tailwindcss": "^4.1.18",
		"taze": "^19.9.2",
		"typescript": "~5.8.3",
		"vue-tsc": "^3.1.8"
	},
	"lint-staged": {
		"*.{js,ts,mjs,cjs,vue}": [
			"pnpm oxlint --fix"
		],
		"*.{js,ts,mjs,cjs,vue,json,yml,md,html,css}": [
			"pnpm oxfmt"
		]
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"engines": {
		"node": ">=24",
		"pnpm": ">=10"
	},
	"volta": {
		"node": "24.13.0"
	},
	"packageManager": "pnpm@10.29.2"
}
